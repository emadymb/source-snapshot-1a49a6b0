# ── Fiksu environment ─────────────────────────────────────────────
# Copy to `.env` and adjust for your machine.  `docker compose up -d`
# provisions Postgres/Redis/MinIO with these defaults.

# Admin/migrations connection (superuser). Used for auth + platform work.
DATABASE_URL="postgresql://fiksu:fiksu@localhost:5432/fiksu?schema=public"

# Least-privilege app connection (RLS enforced). Created by the RLS migration
# as role `fiksu_app`. Falls back to DATABASE_URL when unset.
APP_DATABASE_URL="postgresql://fiksu_app:fiksu_app@localhost:5432/fiksu?schema=public"

# JWT signing secret for access tokens (use a long random value in production).
JWT_SECRET="change-me-to-a-long-random-secret"

# Redis (cache / queues)
REDIS_URL="redis://localhost:6379"

# MinIO / S3-compatible object storage
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="fiksu"
S3_REGION="us-east-1"

# Lovable AI Gateway (OCR + assistant). Optional in local dev.
LOVABLE_API_KEY=""
